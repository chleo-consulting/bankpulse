title Personal Finance Management Data Model

users [icon: user, color: blue] {
  id uuid pk
  email varchar
  password_hash text
  first_name varchar
  last_name varchar
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp
}

organizations [icon: building, color: purple] {
  id uuid pk
  name varchar
  owner_id uuid fk
  created_at timestamp
  deleted_at timestamp
}

bank_accounts [icon: credit-card, color: green] {
  id uuid pk
  user_id uuid fk
  account_name varchar
  iban varchar
  account_type varchar
  balance numeric
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp
}

merchants [icon: shopping-bag, color: orange] {
  id uuid pk
  name varchar
  normalized_name varchar
  created_at timestamp
  deleted_at timestamp
}

categories [icon: folder, color: yellow] {
  id uuid pk
  name varchar
  parent_id uuid fk
  icon varchar
  created_at timestamp
  deleted_at timestamp
}

transactions [icon: dollar-sign, color: green] {
  id uuid pk
  account_id uuid fk
  merchant_id uuid fk
  amount numeric
  transaction_date date
  booking_date date
  description text
  category_id uuid fk
  is_pending boolean
  created_at timestamp
  updated_at timestamp
}

tags [icon: tag, color: gray] {
  id uuid pk
  name varchar
  created_at timestamp
  deleted_at timestamp
}

transaction_tags [icon: link] {
  transaction_id uuid pk, fk
  tag_id uuid pk, fk
}

budgets [icon: pie-chart, color: red] {
  id uuid pk
  user_id uuid fk
  category_id uuid fk
  period_type varchar
  amount_limit numeric
  created_at timestamp
  deleted_at timestamp
}

recurring_rules [icon: repeat, color: purple] {
  id uuid pk
  merchant_id uuid fk
  expected_amount numeric
  frequency varchar
  last_detected date
  created_at timestamp
  deleted_at timestamp
}

audit_logs [icon: file-text, color: gray] {
  id uuid pk
  user_id uuid fk
  entity_type varchar
  entity_id uuid
  action varchar
  old_values jsonb
  new_values jsonb
  ip_address varchar
  user_agent text
  created_at timestamp
}

users.id < organizations.owner_id